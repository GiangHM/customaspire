# Environment variables for podman-compose / docker compose
# Copy this file to .env and fill in values before running:
#   cp .env.example .env

# PostgreSQL password (required - no default for security)
# Generate a strong password: openssl rand -base64 16
POSTGRES_PASSWORD=
POSTGRES_DB=aspiredb

# Container image references (override with locally built images if needed)
# Example: API_IMAGE=my-registry/aspire-api:1.0.0
API_IMAGE=aspire-api:latest
